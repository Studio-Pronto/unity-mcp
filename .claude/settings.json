{
  "permissions": {
    "allow": [
      "mcp__unity",
      "Edit(reports/**)",
      "MultiEdit(reports/**)"
    ],
    "deny": [
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/session-set-tab-name.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/notify-stop.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id // empty' | xargs -I{} terminal-notifier -remove 'claude-{}' 2>/dev/null; exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/notify-attention.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
